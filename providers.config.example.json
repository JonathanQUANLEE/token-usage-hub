    {
      "id": "example-live-provider",
      "name": "Optional: Live API Usage",
      "mode": "http-json",
      "enabled": false,
      "unit": "tokens",
      "timeoutMs": 15000,
      "request": {
        "url": "https://api.example.com/v1/usage",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer ${EXAMPLE_API_KEY}"
        }
      },
      "mapping": {
        "usedTokensPath": "data.used_tokens",
        "limitTokensPath": "data.limit_tokens"
      }
    }
